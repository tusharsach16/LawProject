# Database Configuration
MONGODB_URL=your_mongodb_connection_string_here

# Server Configuration
PORT=5000

# Authentication
JWT_SECRET=your_jwt_secret_here

# Cloudinary (Image Uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# AI Service (Google Gemini)
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Email Configuration (Nodemailer/SMTP)
EMAIL_USER=your_email_address_here
EMAIL_PASSWORD=your_email_app_password_here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email_address_here
SMTP_PASS=your_email_app_password_here

# Cache (Redis)
REDIS_URL=your_redis_url_here

# Payments (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Signaling Server (WebRTC)
SIGNALING_SERVER_URL=http://localhost:8080
SIGNALING_WS_URL=ws://localhost:8080
